ONEMAP_EMAIL=
ONEMAP_PASSWORD=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback if your project still uses the old public anon key name.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google provider foundation. Every capability is fail-closed and remains off unless
# its exact flag and required restricted credential/configuration are both present.
GOOGLE_MAPS_BROWSER_API_KEY=
GOOGLE_MAPS_MAP_ID=
GOOGLE_MAPS_SERVER_API_KEY=
LOCCO_GOOGLE_MAP_ENABLED=
LOCCO_GOOGLE_AUTOCOMPLETE_ENABLED=
LOCCO_GOOGLE_TEXT_SEARCH_ENABLED=
LOCCO_GOOGLE_NEARBY_SEARCH_ENABLED=
LOCCO_GOOGLE_DETAILS_ESSENTIALS_ENABLED=
LOCCO_GOOGLE_DETAILS_PRO_ENABLED=
LOCCO_GOOGLE_DETAILS_ENTERPRISE_ENABLED=
LOCCO_GOOGLE_RATINGS_ENABLED=
LOCCO_GOOGLE_OPENING_HOURS_ENABLED=
LOCCO_GOOGLE_PHOTOS_ENABLED=
LOCCO_GOOGLE_GEOCODING_ENABLED=
LOCCO_GOOGLE_ROUTES_ENABLED=
LOCCO_GOOGLE_PLACE_RECONCILIATION_ENABLED=
LOCCO_GOOGLE_KILL_SWITCH=

# Non-production diagnostics only; ignored in production builds.
LOCCO_PROVIDER_DEV_CONTROLS_ENABLED=
